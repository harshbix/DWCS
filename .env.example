# EcoCollect Tanzania Configuration Environment Settings

# Frontend Variables (Next.js)
# The URL of your Supabase project (from Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# The anonymous API key of your Supabase project (from Project Settings -> API)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
# The core API URL of the Express backend service
NEXT_PUBLIC_API_URL="http://localhost:5000"
# Build environment mode ("development", "production", or "test")
NODE_ENV="development"

# Backend Variables (Express)
# The port the Express server will listen on (defaults to 5000)
PORT=5000
# The URL of your Supabase project (from Project Settings -> API)
SUPABASE_URL="https://your-project.supabase.co"
# The elevated service role key for administrative operations (from Project Settings -> API)
# WARNING: Keep this secure and never expose it to client-side code!
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
# PostgreSQL database connection URI string
DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres"
# Allowed CORS origins (e.g. "http://localhost:3000" or "*" for any)
CORS_ORIGIN="*"
